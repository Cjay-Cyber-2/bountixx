# ── Clerk authentication (REQUIRED) ──
# Clerk Dashboard → Configure → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# REQUIRED — without these Clerk sends users to accounts.dev (hosted UI)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard

# ── Database (Neon Postgres) (REQUIRED) ──
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── App URL (used for Stripe/Paystack redirects) ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI challenge structuring (REQUIRED for "Analyze with AI") ──
# Groq is the primary provider. Gemini is optional fallback if you add it later.
# Multiple Groq keys: comma-separated in one variable (auto-rotates on rate limits).
# Example: GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3
# Or use GROQ_API_KEY_1, GROQ_API_KEY_2, … if you prefer separate vars.
GROQ_API_KEY=
# GEMINI_API_KEY=

# ── Optional: payments ──
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYSTACK_SECRET_KEY=

# Optional: unlimited-coins owner account (matched against the signed-in email)
# ADMIN_EMAIL=chijiokejoseph2022@gmail.com

# ── Optional: browser push notifications (Firebase Cloud Messaging ONLY) ──
# Auth does NOT use Firebase. Only add these if you want push notifications.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FCM_VAPID_KEY=
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
